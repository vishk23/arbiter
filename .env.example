# Arbiter API Keys
# Copy this file to .env and fill in your keys.
# At minimum, you need ONE provider key (OpenAI recommended).
# For multi-provider debates, add keys for 2-3 providers.

# OpenAI (required for most features)
OPENAI_API_KEY=

# Anthropic (Claude) — recommended for deep reasoning
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# xAI Grok — adds provider diversity
XAI_API_KEY=

# DeepSeek (optional, budget provider)
DEEPSEEK_API_KEY=

# Tavily (optional, web search for source retrieval)
TAVILY_API_KEY=
